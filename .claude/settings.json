{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(*)",
      "PowerShell(*)",
      "mcp__*",
      "Edit(**)",
      "Write(**)",
      "Edit(./**)",
      "Write(./**)",
      "Edit(/.claude/**)",
      "Write(/.claude/**)",
      "Edit(/scripts/**)",
      "Write(/scripts/**)",
      "Edit(/proposals/**)",
      "Write(/proposals/**)",
      "Edit(/.tmp/**)",
      "Write(/.tmp/**)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(del:*)",
      "PowerShell(Remove-Item*)",
      "PowerShell(rm *)",
      "PowerShell(del *)"
    ],
    "deny": [
      "PowerShell(Expand-Archive*)",
      "Bash(unzip:*)"
    ]
  }
}